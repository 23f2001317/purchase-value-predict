{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run FastAPI Backend",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "justMyCode": true
        },
        {
            "name": "Run Streamlit Frontend",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "app.py"
            ],
            "cwd": "${workspaceFolder}/frontend",
            "justMyCode": true
        }
    ]
}
